generator client {
  provider = "prisma-client-js"
  output     = "./generated"



}

datasource db {
  provider = "mysql"
}

model Organization {
  id                   String             @id @default(uuid())
  name                 String
  slug                 String             @unique
  logoUrl              String?            @db.Text
  plan                 PlanType           @default(FREE_TRIAL)
  subscriptionStatus   SubscriptionStatus @default(TRIALING)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  trialEndsAt          DateTime
  currentPeriodEnd     DateTime?
  maxTours             Int                @default(1)
  maxImagesPerTour     Int                @default(10)
  totalStorageMb       Int                @default(500)
  usedStorageMb        Int                @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  invitations          Invitation[]
  invoices             Invoice[]
  tours                Tour[]
  users                User[]
  comparisons          Comparison[]


  @@map("organizations")
}

model User {
  id              String       @id @default(uuid())
  email           String       @unique
  password        String
  firstName       String
  lastName        String
  avatarUrl       String?      @db.Text
  role            UserRole     @default(ADMIN)  // Changed from MEMBER: first user of org is now ADMIN
  isVerified      Boolean      @default(false)
  lastLoginAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organizationId  String
  invitationsSent Invitation[] @relation("InvitedBy")
  sessions        Session[]
  tours           Tour[]
  comparisons     Comparison[]
  auditLogs       AuditLog[]

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId], map: "users_organizationId_fkey")
  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique @db.VarChar(512)
  expiresAt DateTime
  ipAddress String?
  userAgent String?  @db.Text
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "sessions_userId_fkey")
  @@map("sessions")
}

model Invitation {
  id             String       @id @default(uuid())
  email          String
  role           UserRole     @default(MEMBER)
  token          String       @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())
  organizationId String
  invitedById    String
  invitedBy      User         @relation("InvitedBy", fields: [invitedById], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([invitedById], map: "invitations_invitedById_fkey")
  @@index([organizationId], map: "invitations_organizationId_fkey")
  @@map("invitations")
}

model Tour {
  id             String       @id @default(uuid())
  title          String
  description    String?      @db.Text
  coverImageUrl  String?      @db.Text
  status         TourStatus   @default(DRAFT)
  shareToken     String       @unique @default(uuid())
  isPublic       Boolean      @default(false)
  viewCount      Int          @default(0)
  settings       Json
  organizationId String
  createdById    String
  createdAt      DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  customLogoUrl      String?      @db.Text
  backgroundAudioUrl String?      @db.Text
  backgroundAudioVolume Float    @default(0.5)
  showSceneMenu      Boolean      @default(true)
  showHotspotTitles  Boolean      @default(true)
  images             TourImage[]
  createdBy      User         @relation(fields: [createdById], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([createdById], map: "tours_createdById_fkey")
  @@index([organizationId], map: "tours_organizationId_fkey")
  @@map("tours")
}

model TourImage {
  id           String    @id @default(uuid())
  tourId       String
  filename     String
  originalName String
  mimeType     String    @default("image/jpeg")
  sizeMb       Float
  width        Int
  height       Int
  order        Int       @default(0)
  title        String?
  initialYaw   Float     @default(0)
  initialPitch Float     @default(0)
  initialFov   Float     @default(1.5707963)
  createdAt    DateTime  @default(now())
  hotspots     Hotspot[]
  tour         Tour      @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId], map: "tour_images_tourId_fkey")
  @@map("tour_images")
}

model Hotspot {
  id            String          @id @default(uuid())
  imageId       String
  type          HotspotType     @default(LINK)
  yaw           Float
  pitch         Float
  rotation      Float           @default(0)
  targetImageId String?
  title         String?
  content       String?         @db.Text
  url           String?         @db.Text
  videoUrl      String?         @db.Text
  imageUrl      String?         @db.Text
  imageUrls     String?         @db.Text
  animationType AnimationType   @default(NONE)
  iconUrl       String?         @db.Text
  iconName      String?         @default("info")
  color         String?
  scale         Float           @default(1.0)
  metadata      Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  image         TourImage       @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@index([imageId], map: "hotspots_imageId_fkey")
  @@map("hotspots")
}

model Plan {
  id                   String   @id @default(uuid())
  name                 String
  planType             PlanType @unique
  priceMonthly         Float
  priceYearly          Float
  stripePriceMonthlyId String?
  stripePriceYearlyId  String?
  maxTours             Int
  maxImagesPerTour     Int
  maxStorageMb         Int
  features             Json
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())

  @@map("plans")
}

model Invoice {
  id              String        @id @default(uuid())
  organizationId  String
  stripeInvoiceId String        @unique
  invoiceNumber   String?
  amount          Float
  currency        String        @default("usd")
  status          InvoiceStatus @default(OPEN)
  description     String?
  pdfUrl          String?       @db.Text
  hostedUrl       String?       @db.Text
  periodStart     DateTime?
  periodEnd       DateTime?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId], map: "invoices_organizationId_fkey")
  @@map("invoices")
}

enum UserRole {
  SUPER_ADMIN  // SaaS platform administrator (manually assigned by developers only)
  ADMIN        // Organization administrator (replaces OWNER)
  MEMBER       // Standard team member
  VIEWER       // Read-only access
}

enum PlanType {
  FREE_TRIAL
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum TourStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum HotspotType {
  LINK
  INFO
  URL
  VIDEO
  LINK_SCENE  // added this for better clarity, represents a hotspot that links to another scene/image
  IMAGE
  TEXT
  OTHER
}

enum AnimationType {
  NONE
  PULSE
  GLOW
  BOUNCE
  FLOAT
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

model Comparison {
  id               String           @id @default(uuid())
  title            String?
  organizationId   String
  createdById      String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  images           ComparisonImage[]
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy        User             @relation(fields: [createdById], references: [id])

  @@index([organizationId], map: "comparisons_organizationId_fkey")
  @@index([createdById], map: "comparisons_createdById_fkey")
  @@map("comparisons")
}

model ComparisonImage {
  id               String     @id @default(uuid())
  comparisonId     String
  filename         String
  originalName     String
  mimeType         String     @default("image/jpeg")
  sizeMb           Float
  width            Int
  height           Int
  captureDate      DateTime
  createdAt        DateTime   @default(now())
  comparison       Comparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)

  @@index([comparisonId], map: "comparison_images_comparisonId_fkey")
  @@map("comparison_images")
}

model AuditLog {
  id              String   @id @default(uuid())
  userId          String
  action          String   // e.g., "APPROVE_INSCRIPTION", "UPDATE_USER_ROLE", "DELETE_TOUR"
  resourceType    String   // e.g., "InscriptionRequest", "User", "Tour"
  resourceId      String
  changes         Json?    // JSON object with before/after values
  ipAddress       String?
  userAgent       String?  @db.Text
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "audit_logs_userId_fkey")
  @@index([action], map: "audit_logs_action_idx")
  @@index([createdAt], map: "audit_logs_createdAt_idx")
  @@map("audit_logs")
}

model InscriptionRequest {
  id                String               @id @default(uuid())
  type              InscriptionType      @default(FREE) // FREE or PROFESSIONAL
  firstName         String
  lastName          String
  email             String               @unique
  phone            String?
  company          String?
  country          String?
  // Professional tier fields
  numberOfTours    Int?
  imagesPerTour    Int?
  teamMembers      Int?
  frequency        String? // monthly or annual
  // Status
  status           InscriptionStatus    @default(PENDING)
  approvedAt       DateTime?
  rejectionReason  String?
  // Metadata
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([email], map: "inscription_requests_email_idx")
  @@index([status], map: "inscription_requests_status_idx")
  @@map("inscription_requests")
}

enum InscriptionType {
  FREE
  PROFESSIONAL
}

enum InscriptionStatus {
  PENDING
  APPROVED
  REJECTED
}
