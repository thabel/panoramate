# Database
DATABASE_URL="mysql://user:password@localhost:3306/panoramate"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-must-be-at-least-32-characters-long!!"
NEXTAUTH_URL="http://localhost:3000"

# Stripe Configuration
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (create these in Stripe Dashboard)
STRIPE_PRICE_STARTER_MONTHLY="price_..."
STRIPE_PRICE_PROFESSIONAL_MONTHLY="price_..."
STRIPE_PRICE_ENTERPRISE_MONTHLY="price_..."

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB="100"

# Email Configuration (choose one provider: smtp, sendgrid, or mailgun)
EMAIL_PROVIDER="smtp"  # Options: smtp, sendgrid, mailgun

# SMTP Configuration (if EMAIL_PROVIDER=smtp)
EMAIL_SMTP_HOST="smtp.gmail.com"
EMAIL_SMTP_PORT="587"
EMAIL_SMTP_SECURE="false"
EMAIL_SMTP_USER="your-email@gmail.com"
EMAIL_SMTP_PASS="your-app-password"

# SendGrid Configuration (if EMAIL_PROVIDER=sendgrid)
# SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxxx"

# Mailgun Configuration (if EMAIL_PROVIDER=mailgun)
# MAILGUN_API_KEY="key-xxxxxxxxxxxxxxxxxxxxx"
# MAILGUN_DOMAIN="mail.yourdomain.com"

# Email Settings
EMAIL_FROM_NAME="Panoramate"
EMAIL_FROM_ADDRESS="noreply@panoramate.com"
